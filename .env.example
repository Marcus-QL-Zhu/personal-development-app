# Copy this file to .env and fill only the keys you actually use.
# Real secrets stay local and must not be committed.

# Backend persistence
GAMEVOICE_DB_PATH=.runtime/gamevoice.db

# Tencent ASR / realtime transcription
TENCENT_APP_ID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_REGION=ap-shanghai
TENCENT_ASR_ENGINE=16k_zh
TENCENT_FLASH_ASR_ENABLED=true
TENCENT_FLASH_ASR_ENGINE=16k_zh
TENCENT_FLASH_ASR_SPEAKER_DIARIZATION=1
TENCENT_FLASH_ASR_TIMEOUT_SECONDS=180
TENCENT_REALTIME_ENGINE=16k_zh_en_speaker
TENCENT_REALTIME_NEED_VAD=1
TENCENT_REALTIME_SPEAKER_DIARIZATION=1
TENCENT_REALTIME_VOICE_FORMAT=1
TENCENT_REALTIME_ENABLE_SPEAKER_CONTEXT=1
TENCENT_REALTIME_CHUNK_BYTES=6400
TENCENT_REALTIME_KEEPALIVE_SECONDS=4
TENCENT_REALTIME_EXPIRED_SECONDS=3600

# LLM / preview / TTS providers
MINIMAX_API_KEY=
MINIMAX_TEXT_MODEL=MiniMax-M2.7-highspeed
MINIMAX_TEXT_BASE_URL=https://api.minimaxi.com/v1/text/chatcompletion_v2
MINIMAX_TEXT_TIMEOUT_SECONDS=20
MINIMAX_REASONING_ENABLED=true
MINIMAX_REASONING_MODEL=MiniMax-M3
MINIMAX_REASONING_BASE_URL=https://api.minimaxi.com/v1/chat/completions
MINIMAX_REASONING_THINKING_TYPE=adaptive
MINIMAX_REASONING_SPLIT=true
MINIMAX_REASONING_TIMEOUT_SECONDS=600
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=
MINIMAX_TTS_BASE_URL=wss://api.minimaxi.com/ws/v1/t2a_v2
MINIMAX_TTS_TIMEOUT_SECONDS=15
MINIMAX_TTS_OUTPUT_DIR=.runtime/tts
SILICONFLOW_API_KEY=
SILICONFLOW_PREVIEW_MODEL=Qwen/Qwen3-8B
SILICONFLOW_PREVIEW_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_PREVIEW_TIMEOUT_SECONDS=8
SILICONFLOW_PREVIEW_MAX_TOKENS=50
SILICONFLOW_PREVIEW_TEMPERATURE=0
SILICONFLOW_PREVIEW_TOP_P=0.8
SILICONFLOW_PREVIEW_TOP_K=40
SILICONFLOW_PREVIEW_MIN_P=0
SILICONFLOW_PREVIEW_FREQUENCY_PENALTY=0.2
SILICONFLOW_ALIAS_REWRITE_MODEL=deepseek-ai/DeepSeek-V4-Flash
SILICONFLOW_ALIAS_REWRITE_TIMEOUT_SECONDS=30

# Personal development / Feishu Bitable
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_BASE_URL=https://your-tenant.feishu.cn/base
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
PERSONAL_DEVELOPMENT_AUDIO_RETENTION_DAYS=90

# Search and speaker tooling
METASO_API_KEY=
PYANNOTEAI_API_KEY=
SPEAKER_LIVE_PYANNOTE_MODEL_ID=pyannote/speaker-diarization-community-1
SPEAKER_LIVE_WESPEAKER_MODEL_NAME=chinese
WESPEAKER_HOME=

# Local assets and tuning
ARKHAM_RULES_ZIP_PATH=C:\Clawdspace\arkham-rules.zip
ARKHAM_CARDS_ZIP_PATH=C:\Clawdspace\arkhamdb-cards.zip
MEMORY_COMPACTION_TOKEN_THRESHOLD=40000
ASSISTANT_AUTO_REPLY_COOLDOWN_SECONDS=4
